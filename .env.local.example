# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Resend (email) ────────────────────────────────────────────────────────────
# Get your API key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=certificates@shortstopelectric.com

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://learn.shortstopelectric.com
# CE Provider ID issued by Washington L&I
NEXT_PUBLIC_CE_PROVIDER_ID=WA-CE-PROV-XXXX
